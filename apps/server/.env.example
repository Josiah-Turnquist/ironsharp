# ── Neon Postgres ────────────────────────────────────────────────
# Copy your Neon connection string here (Dashboard → Connection Details).
# Use the *pooled* connection string for the running server.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# ── Better Auth ──────────────────────────────────────────────────
# Long random secret. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="replace-me-with-a-long-random-secret"
# Public URL the server is reachable at (Railway gives you one).
# Locally this is http://localhost:8787
BETTER_AUTH_URL="http://localhost:8787"

# ── Server ───────────────────────────────────────────────────────
# Locally the server defaults to 8787. Railway injects PORT automatically.
PORT=8787

# OPTIONAL. The app's own URL schemes (ironsharp://, exp://, localhost) are
# already trusted in code (src/config.ts) — you do NOT need to set this. Only
# add it to append extra origins, e.g. a future web client:
# TRUSTED_ORIGINS="https://app.ironsharp.com"

# ── Social sign-in (optional) ────────────────────────────────────
# Leave blank to disable. Fill in to enable Google / Apple buttons.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
APPLE_CLIENT_ID=""
APPLE_CLIENT_SECRET=""
